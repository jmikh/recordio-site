---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header";
import Hero from "../components/Hero";
import SplineBackground from "../components/SplineBackground";
import BeforeAfterComparison from "../components/BeforeAfterComparison";
import InteractiveShowcase from "../components/features/InteractiveShowcase";
import FeatureBento from "../components/features/FeatureBento";
import Pricing from "../components/Pricing";
import FAQ from "../components/FAQ";
import Footer from "../components/Footer";
---

<BaseLayout
    title="Recordio — Professional Screen Recordings, Auto-Polished | Chrome Extension"
    description="Record your screen and get auto-zoom, spotlight, and captions — polished and ready to share. Recordio is the Chrome extension that turns raw recordings into professional videos in seconds."
>
    <Header client:load />
    <main>
        <!-- Hero section wrapper: positions Spline behind Hero content -->
        <div class="relative">
            <div class="absolute inset-0 w-full h-full pointer-events-none z-0">
                <SplineBackground client:idle />
            </div>
            <Hero client:load />
        </div>
        <BeforeAfterComparison client:visible />
        <InteractiveShowcase client:visible />
        <FeatureBento client:visible />
        <Pricing client:visible />
        <FAQ client:visible />
    </main>
    <Footer client:visible />
</BaseLayout>
