---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header";
import Hero from "../components/Hero";
import FeatureVideos from "../components/FeatureVideos";
import Testimonials from "../components/Testimonials";
import Pricing from "../components/Pricing";
import FAQ from "../components/FAQ";
import Footer from "../components/Footer";
---

<BaseLayout
    title="Recordio — Professional Screen Recordings, Auto-Polished | Chrome Extension"
    description="Record your screen and get auto-zoom, spotlight, and captions — polished and ready to share. Recordio is the Chrome extension that turns raw recordings into professional videos in seconds."
>
    <Header client:load />
    <main>
        <Hero client:load />
        <FeatureVideos client:visible />
        <Testimonials client:visible />
        <Pricing client:visible />
        <FAQ client:visible />
    </main>
    <Footer client:visible />
</BaseLayout>
