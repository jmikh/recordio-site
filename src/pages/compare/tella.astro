---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header";
import Footer from "../../components/Footer";
import CompareHero from "../../components/compare/CompareHero";
import CompareValueProps from "../../components/compare/CompareValueProps";
import CompareFeatureTable from "../../components/compare/CompareFeatureTable";
import CompareCTA from "../../components/compare/CompareCTA";
import FeatureVideos from "../../components/FeatureVideos";
import Pricing from "../../components/Pricing";

const compareNavLinks = [
    { label: 'Comparison', href: '#comparison' },
    { label: 'Features', href: '#feature-videos' },
    { label: 'Pricing', href: '#pricing' },
];

const valueProps = [
    {
        title: "No Monthly Subscription Required",
        description:
            "Tella starts at $19/user/month with no free plan — just a 7-day trial. Recordio is free to start, $48/yr, or $89 lifetime with no per-seat pricing.",
    },
    {
        title: "Everything Runs Locally",
        description:
            "Tella uploads your recordings to the cloud for processing. Recordio processes everything in your browser — your data never leaves your machine.",
    },
    {
        title: "Smarter Zoom, Not Manual Layouts",
        description:
            "Tella offers manual multi-layout switching. Recordio's DOM-aware Auto Zoom intelligently follows your clicks and interactions — no setup required.",
    },
    {
        title: "Polish Without the Learning Curve",
        description:
            "Tella requires you to plan clips, switch layouts, and edit a transcript. Recordio gives you auto zoom, spotlight, AutoCut, and device frames with zero editing.",
    },
];

const featureRows = [
    {
        feature: "Platform",
        recordio: "Chrome, Edge, Brave",
        competitor: "Web app, Chrome, macOS, Windows",
    },
    {
        feature: "Auto Zoom",
        description: "Automatic zoom on interactions",
        recordio: "DOM-aware, automatic",
        competitor: "Manual zoom effects",
    },
    {
        feature: "Auto Spotlight",
        description: "3D elevation on interacted elements",
        recordio: true,
        competitor: false,
    },
    {
        feature: "Simplified Toolbar",
        description: "Hides bookmarks, tabs, and extensions",
        recordio: true,
        competitor: false,
    },
    {
        feature: "Smart AutoCut",
        description: "Automatic silence removal",
        recordio: true,
        competitor: "Filler word & silence removal",
    },
    {
        feature: "Device Frames",
        description: "MacBook Pro / Air frames",
        recordio: true,
        competitor: false,
    },
    {
        feature: "Shareable Links",
        recordio: "With viewership analytics",
        competitor: "Yes (analytics on Premium only)",
    },
    {
        feature: "Auto Captions",
        recordio: "Local, 99 languages, word-level highlighting",
        competitor: "AI-generated subtitles",
    },
    {
        feature: "Custom Backgrounds",
        recordio: true,
        competitor: true,
    },
    {
        feature: "Built-In Editor",
        description: "Edit without leaving the app",
        recordio: true,
        competitor: "Transcript-based editor",
    },
    {
        feature: "Video Library",
        description: "Organize and manage past recordings",
        recordio: true,
        competitor: true,
    },
    {
        feature: "Local Processing",
        description: "Recordings stay on your machine",
        recordio: true,
        competitor: false,
    },
    {
        feature: "Pricing",
        recordio: "Free / $48yr / $89 lifetime",
        competitor: "No free plan / $19 per user/mo",
    },
];
---

<BaseLayout
    title="Auto-Polished Recordings Without a Subscription — Tella Alternative"
    description="Tella costs $19/user/month with no free plan. Recordio starts free, polishes every recording automatically, and keeps everything local."
    path="/compare/tella"
>
    <Header client:load navLinks={compareNavLinks} />

    <main>
        <CompareHero
            client:load
            competitorName="Tella"
            headline="Recordio vs Tella"
            subheadline="Both make screen recordings look great — but Recordio does it automatically, locally, and without a monthly subscription."
        />

        <CompareValueProps
            client:visible
            competitorName="Tella"
            props={valueProps}
            variant="purple"
        />

        <CompareFeatureTable
            client:visible
            competitorName="Tella"
            rows={featureRows}
            variant="white"
        />

        <FeatureVideos client:visible />
        <Pricing client:visible />

        <CompareCTA
            client:visible
            competitorName="Tella"
            variant="purple"
        />
    </main>

    <Footer client:visible source="compare-tella" />
</BaseLayout>
