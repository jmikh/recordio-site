---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header";
import Footer from "../../components/Footer";
import CompareHero from "../../components/compare/CompareHero";
import CompareValueProps from "../../components/compare/CompareValueProps";
import CompareFeatureTable from "../../components/compare/CompareFeatureTable";
import CompareCTA from "../../components/compare/CompareCTA";
import FeatureVideos from "../../components/FeatureVideos";
import Pricing from "../../components/Pricing";

const compareNavLinks = [
    { label: 'Comparison', href: '#comparison' },
    { label: 'Features', href: '#feature-videos' },
    { label: 'Pricing', href: '#pricing' },
];

const valueProps = [
    {
        title: "No Desktop App Required",
        description:
            "FocuSee requires downloading a desktop app for Mac or Windows. Recordio runs entirely in your browser — Chrome, Edge, or Brave. Nothing to install, nothing to update.",
    },
    {
        title: "Truly Private, Local Processing",
        description:
            "FocuSee processes video on their servers. Recordio does everything in-browser — your recordings never leave your machine unless you choose to share them.",
    },
    {
        title: "Simpler, More Transparent Pricing",
        description:
            "FocuSee charges $50–80/yr and their lifetime plan no longer includes free major updates. Recordio is free to start, $48/yr, or $89 lifetime — with all updates included, forever.",
    },
    {
        title: "DOM-Aware Zoom, Not Cursor Tracking",
        description:
            "FocuSee's auto zoom follows your cursor. Recordio's DOM-aware zoom understands what you're actually clicking on — buttons, inputs, menus — for precise, meaningful zooms every time.",
    },
];

const featureRows = [
    {
        feature: "Platform",
        recordio: "Chrome, Edge, Brave — any OS",
        competitor: "Mac & Windows desktop app",
    },
    {
        feature: "Auto Zoom",
        description: "Automatic zoom on interactions",
        recordio: "DOM-aware, automatic",
        competitor: "Cursor-tracking based",
    },
    {
        feature: "Auto Spotlight",
        description: "3D elevation on interacted elements",
        recordio: true,
        competitor: "Cursor highlight only",
    },
    {
        feature: "Simplified Toolbar",
        description: "Hides bookmarks, tabs, and extensions",
        recordio: true,
        competitor: false,
    },
    {
        feature: "Smart AutoCut",
        description: "Automatic silence removal",
        recordio: "Voice + interaction aware",
        competitor: "Basic silence removal",
    },
    {
        feature: "Device Frames",
        description: "MacBook Pro / Air frames",
        recordio: true,
        competitor: false,
    },
    {
        feature: "Shareable Links",
        recordio: "With viewership analytics",
        competitor: false,
    },
    {
        feature: "Auto Captions",
        recordio: "Local, 99 languages, word-level highlighting",
        competitor: "AI-generated, editable",
    },
    {
        feature: "Custom Backgrounds",
        recordio: true,
        competitor: "Padding & shadow only",
    },
    {
        feature: "Built-In Editor",
        description: "Edit without leaving the app",
        recordio: true,
        competitor: true,
    },
    {
        feature: "Video Library",
        description: "Organize and manage past recordings",
        recordio: true,
        competitor: true,
    },
    {
        feature: "Local Processing",
        description: "Recordings stay on your machine",
        recordio: true,
        competitor: false,
    },
    {
        feature: "Pricing",
        recordio: "Free / $48yr / $89 lifetime",
        competitor: "$50–80/yr / ~$100 lifetime (no major updates)",
    },
];
---

<BaseLayout
    title="Smarter Zoom, No Desktop App Needed — FocuSee Alternative"
    description="FocuSee follows your cursor. Recordio reads the DOM for precise zoom — and runs right in your browser. $89 lifetime, updates included forever."
>
    <Header client:load navLinks={compareNavLinks} />

    <main>
        <CompareHero
            client:load
            competitorName="FocuSee"
            headline="Recordio vs FocuSee"
            subheadline="FocuSee is a solid desktop recorder with auto zoom — but Recordio does it smarter, right in your browser. DOM-aware zoom, 3D spotlight, and transparent pricing with no app to install."
        />

        <CompareValueProps
            client:visible
            competitorName="FocuSee"
            props={valueProps}
            variant="purple"
        />

        <CompareFeatureTable
            client:visible
            competitorName="FocuSee"
            rows={featureRows}
            variant="white"
        />

        <FeatureVideos client:visible />
        <Pricing client:visible />

        <CompareCTA
            client:visible
            competitorName="FocuSee"
            variant="purple"
        />
    </main>

    <Footer client:visible source="compare-focusee" />
</BaseLayout>
