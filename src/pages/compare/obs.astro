---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header";
import Footer from "../../components/Footer";
import CompareHero from "../../components/compare/CompareHero";
import CompareValueProps from "../../components/compare/CompareValueProps";
import CompareFeatureTable from "../../components/compare/CompareFeatureTable";
import CompareCTA from "../../components/compare/CompareCTA";
import FeatureVideos from "../../components/FeatureVideos";
import Pricing from "../../components/Pricing";

const compareNavLinks = [
    { label: 'Comparison', href: '#comparison' },
    { label: 'Features', href: '#feature-videos' },
    { label: 'Pricing', href: '#pricing' },
];

const valueProps = [
    {
        title: "Record and Share in One Tool",
        description:
            "OBS records a file. Recordio records, edits, and gives you a shareable link with analytics — all in one step.",
    },
    {
        title: "Zero Configuration",
        description:
            "OBS requires scenes, sources, and encoder setup. Recordio is a Chrome extension — install and start recording in seconds.",
    },
    {
        title: "Automatic Post-Processing",
        description:
            "Auto zoom, spotlight, clean toolbar, device frames, and AutoCut — all applied automatically. No separate editor needed.",
    },
    {
        title: "Built for Product Videos",
        description:
            "OBS is designed for live streaming. Recordio is purpose-built for demos, tutorials, and walkthroughs.",
    },
];

const featureRows = [
    {
        feature: "Setup",
        recordio: "Chrome extension, instant",
        competitor: "Desktop app, manual configuration",
    },
    {
        feature: "Auto Zoom",
        description: "Automatic zoom on interactions",
        recordio: "DOM-aware, automatic",
        competitor: false,
    },
    {
        feature: "Auto Spotlight",
        description: "3D elevation on interacted elements",
        recordio: true,
        competitor: false,
    },
    {
        feature: "Simplified Toolbar",
        recordio: true,
        competitor: false,
    },
    {
        feature: "Smart AutoCut",
        description: "Automatic silence removal",
        recordio: true,
        competitor: false,
    },
    {
        feature: "Device Frames",
        recordio: true,
        competitor: false,
    },
    {
        feature: "Shareable Links",
        recordio: "With viewership analytics",
        competitor: false,
    },
    {
        feature: "Auto Captions",
        recordio: "Local, 99 languages",
        competitor: false,
    },
    {
        feature: "Built-In Editor",
        description: "Edit without leaving the app",
        recordio: true,
        competitor: false,
    },
    {
        feature: "Custom Backgrounds",
        recordio: true,
        competitor: false,
    },
    {
        feature: "Video Library",
        description: "Organize and manage past recordings",
        recordio: true,
        competitor: false,
    },
    {
        feature: "Cross-Platform",
        recordio: "Any OS via Chrome/Edge/Brave",
        competitor: "Mac, Windows, Linux",
    },
];
---

<BaseLayout
    title="Record, Polish, and Share in One Click — OBS Alternative"
    description="OBS is built for streaming. Recordio is built for product demos. Auto zoom, spotlight, clean toolbar, and shareable links — zero configuration."
>
    <Header client:load navLinks={compareNavLinks} />

    <main>
        <CompareHero
            client:load
            competitorName="OBS"
            headline="Recordio vs OBS"
            subheadline="Purpose-built for product demos and tutorials. Record, polish, and share — no scenes, no sources, no encoding settings."
        />

        <CompareValueProps
            client:visible
            competitorName="OBS"
            props={valueProps}
            variant="purple"
        />

        <CompareFeatureTable
            client:visible
            competitorName="OBS"
            rows={featureRows}
            variant="white"
        />

        <FeatureVideos client:visible />
        <Pricing client:visible />

        <CompareCTA
            client:visible
            competitorName="OBS"
            variant="purple"
        />
    </main>

    <Footer client:visible source="compare-obs" />
</BaseLayout>
