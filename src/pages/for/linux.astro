---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header";
import Footer from "../../components/Footer";
import PlatformHero from "../../components/platform/PlatformHero";
import FeatureVideos from "../../components/FeatureVideos";
import Testimonials from "../../components/Testimonials";
import Pricing from "../../components/Pricing";
import FAQ from "../../components/FAQ";
---

<BaseLayout
    title="Best Screen Recorder for Linux & Ubuntu in 2026 — Recordio"
    description="The best screen recorder for Linux and Ubuntu. Auto-zoom, spotlight, and AI captions built into your browser. No native app dependencies. Works on Chrome, Edge, and Brave. Free to start."
>
    <Header client:load />

    <main>
        <PlatformHero
            client:load
            platformName="Linux"
            tagLabel="Best for Linux & Ubuntu"
            headline="The best screen recorder for <span class='underline decoration-primary decoration-4 underline-offset-4'>Linux.</span>"
            subheadline="No PPA, no Snap, no Flatpak. Recordio runs entirely in your browser — Chrome, Edge, or Brave on any distro. Hit record, and every video comes out polished with auto-zoom, spotlight, and captions."
        />

        <FeatureVideos client:visible />
        <Testimonials client:visible />
        <Pricing client:visible />
        <FAQ client:visible />
    </main>

    <Footer client:visible source="for-linux" />
</BaseLayout>
